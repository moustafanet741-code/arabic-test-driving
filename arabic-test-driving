import { PrismaClient } from '@prisma/client';
import fs from 'fs';
import Papa from 'papaparse';

const prisma = new PrismaClient();

async function seed() {
  // Seed questions from CSV
  const csvData = fs.readFileSync('./data/questions.csv', 'utf8');
  const parsed = Papa.parse(csvData, { header: true }).data;

  for (const row of parsed) {
    await prisma.question.upsert({
      where: { code: row.code },
      update: {},
      create: {
        code: row.code,
        category: row.category,
        section: row.section,
        difficulty: row.difficulty,
        questionArabic: row.questionArabic,
        questionGreek: row.questionGreek,
        questionGreekAr: row.questionGreekAr,
        option1: row.option1,
        option2: row.option2,
        option3: row.option3,
        correctAnswer: parseInt(row.correctAnswer),
        explanation: row.explanation,
        image: row.image,
        icon: row.icon,
      },
    });
  }

  console.log('Database seeded successfully!');
}

seed().catch(e => console.error(e)).finally(() => prisma.$disconnect());
