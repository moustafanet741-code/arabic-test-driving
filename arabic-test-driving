export default function ReadyTests() {
  const [questions, setQuestions] = useState<any[]>([]);
  const [currentQuestionIndex, setCurrentQuestionIndex] = useState(0);
  const [score, setScore] = useState(0);
  const [isLoading, setIsLoading] = useState(true);
  const [testCompleted, setTestCompleted] = useState(false);
  const { data: session } = useSession();
  const router = useRouter();

  useEffect(() => {
    loadQuestions();
  }, []);

  const loadQuestions = async () => {
    try {
      setIsLoading(true);
      const data = await fetchQuestions({ count: 20 }); // 20 demo questions
      setQuestions(data);
    } catch (error) {
      console.error('Error:', error);
    } finally {
      setIsLoading(false);
    }
  };

  const handleAnswer = async (isCorrect: boolean) => {
    if (isCorrect) setScore(prev => prev + 1);

    setTimeout(() => {
      if (currentQuestionIndex < questions.length - 1) {
        setCurrentQuestionIndex(prev => prev + 1);
      } else {
        setTestCompleted(true);
        if (session?.user?.id) {
          await saveTestResult({
            userId: session.user.id,
            testType: 'ready_test',
            score: score + 1,
            total: questions.length,
            questions,
          });
        }
      }
    }, 2000);
  };

  if (isLoading) return <div className="p-8 text-center">Ш¬Ш§ШұЩҠ Ш§Щ„ШӘШӯЩ…ЩҠЩ„...</div>;
  if (testCompleted) {
    const percentage = Math.round((score / questions.length) * 100);
    return (
      <div className="min-h-screen py-20 px-4 bg-blue-50 text-center">
        <div className="max-w-2xl mx-auto bg-white p-12 rounded-3xl shadow-2xl">
          <div className={`w-32 h-32 mx-auto mb-8 rounded-full flex items-center justify-center text-5xl ${
            percentage >= 75 ? 'bg-green-500 text-white' : 'bg-red-500 text-white'
          }`}>
            {percentage >= 75 ? 'вң…' : 'вқҢ'}
          </div>
          <h1 className="text-5xl font-bold mb-6">{percentage >= 75 ? 'Щ…ШЁШұЩҲЩғ!' : 'ШӯШ§ЩҲЩ„ Щ…ШұШ© ШЈШ®ШұЩү'}</h1>
          <div className="text-4xl font-bold text-blue-600 mb-8">
            {score} / {questions.length} ({percentage}%)
          </div>
          <div className="space-x-4">
            <button onClick={() => router.push('/tests/ready')} 
                    className="bg-blue-600 text-white px-8 py-4 rounded-2xl font-bold text-xl">
              Ш§Ш®ШӘШЁШ§Шұ Ш¬ШҜЩҠШҜ
            </button>
            <button onClick={() => router.push('/')} 
                    className="border-2 border-blue-600 text-blue-600 px-8 py-4 rounded-2xl font-bold text-xl">
              Ш§Щ„ШұШҰЩҠШіЩҠШ©
            </button>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen py-12 px-4 bg-gradient-to-b from-blue-50 to-white">
      <div className="max-w-4xl mx-auto">
        {/* Progress */}
        <div className="mb-12 bg-white p-6 rounded-2xl shadow-lg">
          <div className="flex justify-between mb-4">
            <span>Ш§Щ„ШіШӨШ§Щ„ {currentQuestionIndex + 1} / {questions.length}</span>
            <span>{score} ШөШӯЩҠШӯ</span>
          </div>
          <div className="w-full bg-gray-200 rounded-full h-4">
            <div className="bg-blue-600 h-4 rounded-full" 
                 style={{width: `${((currentQuestionIndex + 1) / questions.length) * 100}%`}} />
          </div>
        </div>

        {questions[currentQuestionIndex] && (
          <TestQuestion
            question={questions[currentQuestionIndex]}
            onAnswer={handleAnswer}
            questionIndex={currentQuestionIndex}
            totalQuestions={questions.length}
          />
        )}
      </div>
    </div>
  );
}
import { NextRequest, NextResponse } from 'next/server';
import { PrismaClient } from '@prisma/client';
import { getServerSession } from 'next-auth';
import { authOptions } from '@/lib/auth';

const prisma = new PrismaClient();

export async function POST(request: NextRequest) {
  try {
    const session = await getServerSession(authOptions);
    if (!session?.user?.id) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
    }

    const data = await request.json();
    const result = await prisma.testResult.create({
      data: {
        userId: session.user.id,
        testType: data.testType,
        score: data.score,
        total: data.total,
        questions: data.questions,
      },
    });

    return NextResponse.json({ success: true, result });
  } catch (error) {
    return NextResponse.json({ error: 'Server error' }, { status: 500 });
  }
}
