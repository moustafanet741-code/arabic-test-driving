import { NextRequest, NextResponse } from 'next/server';
import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();

export async function GET(request: NextRequest) {
  try {
    const { searchParams } = new URL(request.url);
    const category = searchParams.get('category');
    const section = searchParams.get('section');
    const count = Math.min(parseInt(searchParams.get('count') || '10'), 100);
    
    const where: any = {};
    if (category) where.category = category;
    if (section) where.section = section;

    // О ОЎО‘О“ОңО‘ОӨОҷОҡОҹ RANDOM ОјОө Prisma
    const total = await prisma.question.count({ where });
    const skip = Math.floor(Math.random() * Math.max(0, total - count));
    
    const questions = await prisma.question.findMany({
      where,
      take: count,
      skip,
      orderBy: { id: 'asc' }, // stable order
    });

    return NextResponse.json(questions);
  } catch (error) {
    return NextResponse.json({ error: 'API Error' }, { status: 500 });
  }
}
export async function fetchQuestions(params: {
  category?: string;
  section?: string;
  count?: number;
}) {
  const url = new URL('/api/questions', process.env.NEXTAUTH_URL || 'http://localhost:3000');
  
  if (params.category) url.searchParams.set('category', params.category);
  if (params.section) url.searchParams.set('section', params.section);
  if (params.count) url.searchParams.set('count', params.count.toString());

  const res = await fetch(url.toString());
  if (!res.ok) throw new Error('Failed to fetch');
  return res.json();
}

export async function saveTestResult(data: {
  userId: string;
  testType: string;
  score: number;
  total: number;
  questions: any[];
}) {
  const res = await fetch('/api/tests', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data),
  });
  return res.json();
}
