'use client';
import { useState, useEffect } from 'react';
import { useSession } from 'next-auth/react';
import { useRouter } from 'next/navigation';
import { motion } from 'framer-motion';
import TestQuestion from '@/components/TestQuestion';
import { saveTestResult } from '@/lib/api';

export default function ReadyTests() {
  const [questions, setQuestions] = useState([]);
  const [currentQuestionIndex, setCurrentQuestionIndex] = useState(0);
  const [score, setScore] = useState(0);
  const [isLoading, setIsLoading] = useState(true);
  const [testCompleted, setTestCompleted] = useState(false);
  const { data: session } = useSession();
  const router = useRouter();

  useEffect(() => {
    loadQuestions();
  }, []);

  const loadQuestions = async () => {
    try {
      // Fetch 40 random questions for full test
      const response = await fetch('/api/questions/random?count=40');
      const data = await response.json();
      setQuestions(data);
    } catch (error) {
      console.error('Error loading questions:', error);
    } finally {
      setIsLoading(false);
    }
  };

  const handleAnswer = (isCorrect: boolean) => {
    if (isCorrect) {
      setScore(prev => prev + 1);
    }

    // Move to next question after delay
    setTimeout(() => {
      if (currentQuestionIndex < questions.length - 1) {
        setCurrentQuestionIndex(prev => prev + 1);
      } else {
        setTestCompleted(true);
        if (session) {
          saveTestResult({
            userId: session.user.id,
            testType: 'ready_test',
            score: score + 1,
            total: questions.length,
            questions: questions,
          });
        }
      }
    }, 3000);
  };

  if (isLoading) {
    return (
      <div className="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 to-blue-100">
        <motion.div
          animate={{ rotate: 360 }}
          transition={{ duration: 1, repeat: Infinity, ease: 'linear' }}
          className="w-16 h-16 border-4 border-blue-200 border-t-blue-600 rounded-full"
        />
      </div>
    );
  }

  if (testCompleted) {
    const percentage = Math.round((score / questions.length) * 100);
    const passed = percentage >= 75;

    return (
      <div className="min-h-screen py-24 px-4 bg-gradient-to-br from-blue-50 to-blue-100">
        <div className="max-w-4xl mx-auto">
          <motion.div
            initial={{ opacity: 0, scale: 0.8 }}
            animate={{ opacity: 1, scale: 1 }}
            className="bg-white rounded-3xl shadow-2xl p-12 md:p-20 text-center"
          >
            <motion.div
              animate={{ scale: [1, 1.2, 1] }}
              transition={{ duration: 0.5 }}
              className={`w-32 h-32 mx-auto mb-8 rounded-3xl flex items-center justify-center text-4xl shadow-2xl ${
                passed ? 'bg-green-400 text-white' : 'bg-red-400 text-white'
              }`}
            >
              {passed ? '✅' : '❌'}
            </motion.div>
            
            <h1 className="text-5xl md:text-6xl font-bold text-blue-900 mb-6">
              {passed ? 'مبروك!' : 'حاول مرة أخرى'}
            </h1>
            
            <div className="text-4xl font-bold mb-8 text-blue-600">
              {score} / {questions.length}
            </div>
            
            <div className="text-2xl mb-12 text-blue-700">
              {percentage}% - {passed ? 'نجحت!' : 'يجب 75% للنجاح'}
            </div>

            <div className="grid md:grid-cols-2 gap-6 mb-12">
              <div className="bg-blue-50 p-8 rounded-2xl">
                <h3 className="text-2xl font-bold text-blue-900 mb-4">نقاط القوة</h3>
                <p className="text-lg">راجع الأخطاء لتحسين النتيجة القادمة</p>
              </div>
              <div className="bg-green-50 p-8 rounded-2xl">
                <h3 className="text-2xl font-bold text-green-800 mb-4">التقدم</h3>
                <p className="text-lg">
                  {session 
                    ? 'تم حفظ النتيجة في حسابك'
                    : 'قم بتسجيل الدخول لحفظ النتائج'
                  }
                </p>
              </div>
            </div>

            <div className="flex flex-col sm:flex-row gap-4 justify-center">
              <button
                onClick={() => router.push('/tests/ready')}
                className="bg-blue-600 text-white px-12 py-4 rounded-2xl font-bold text-xl hover:bg-blue-700 shadow-xl hover:shadow-2xl transition-all"
              >
                اختبار جديد
              </button>
              <button
                onClick={() => router.push('/dashboard')}
                className="border-2 border-blue-
                border-blue-600 text-blue-600 px-12 py-4 rounded-2xl font-bold text-xl hover:bg-blue-600 hover:text-white transition-all"
              >
                لوحة التحكم
              </button>
            </div>
          </motion.div>
        </div>
      </div>
    );
  }

  const currentQuestion = questions[currentQuestionIndex];

  return (
    <div className="min-h-screen py-12 px-4 bg-gradient-to-br from-blue-50 to-blue-100">
      <div className="max-w-4xl mx-auto">
        {/* Progress Bar */}
        <div className="mb-12">
          <div className="flex justify-between text-sm text-blue-600 font-medium mb-2">
            <span>السؤال {currentQuestionIndex + 1} من {questions.length}</span>
            <span>{score} / {currentQuestionIndex}</span>
          </div>
          <div className="w-full bg-blue-200 rounded-full h-3">
            <div 
              className="bg-gradient-to-r from-blue-500 to-blue-600 h-3 rounded-full transition-all duration-500 shadow-lg"
              style={{ width: `${((currentQuestionIndex + 1) / questions.length) * 100}%` }}
            />
          </div>
        </div>

        {/* Current Question */}
        {currentQuestion && (
          <TestQuestion
            question={currentQuestion}
            onAnswer={handleAnswer}
            questionIndex={currentQuestionIndex}
            totalQuestions={questions.length}
          />
        )}
      </div>
    </div>
  );
}
import { NextRequest, NextResponse } from 'next/server';
import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();

export async function GET(request: NextRequest) {
  const { searchParams } = new URL(request.url);
  const category = searchParams.get('category');
  const section = searchParams.get('section');
  const count = parseInt(searchParams.get('count') || '10');
  const randomize = searchParams.get('randomize') === 'true';

  try {
    let questions;
    
    if (randomize) {
      questions = await prisma.question.findMany({
        take: count,
        orderBy: { id: 'desc' },
        ...(category && { where: { category } }),
        ...(section && { where: { section } }),
      });
    } else {
      questions = await prisma.question.findMany({
        where: {
          ...(category && { category }),
          ...(section && { section }),
        },
        take: count,
      });
    }

    return NextResponse.json(questions);
  } catch (error) {
    return NextResponse.json({ error: 'Failed to fetch questions' }, { status: 500 });
  }
}
import { NextRequest, NextResponse } from 'next/server';
import { PrismaClient } from '@prisma/client';
import { getServerSession } from 'next-auth';
import { authOptions } from '@/lib/auth';

const prisma = new PrismaClient();

export async function POST(request: NextRequest) {
  try {
    const session = await getServerSession(authOptions);
    
    if (!session?.user?.id) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
    }

    const { testType, score, total, questions } = await request.json();

    const testResult = await prisma.testResult.create({
      data: {
        userId: session.user.id,
        testType,
        score,
        total,
        questions,
      },
    });

    return NextResponse.json({ success: true, testResult });
  } catch (error) {
    return NextResponse.json({ error: 'Failed to save test' }, { status: 500 });
  }
}
import NextAuth from 'next-auth';
import GoogleProvider from 'next-auth/providers/google';
